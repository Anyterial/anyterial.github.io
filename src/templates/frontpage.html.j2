<main>
  <section class="hero section-shell" aria-labelledby="hero-title">
    <div class="hero-copy">
      <h1 id="hero-title">Exploring the space of materials, one microsecond at a time.</h1>
      <p class="hero-lede">Anyterial is our gateway to high-quality data, tools, and documentation for computational materials science associated with the <a href="https://httk.org">High-Throughput Toolkit (<i>httk</i>)</a>.</p>
      <div class="hero-actions">
        <a class="button primary" href="#databases">Explore resources <span aria-hidden="true">→</span></a>
        <a class="button secondary" href="{{ page.relbaseurl }}/about.html">Learn more <span aria-hidden="true">ⓘ</span></a>
      </div>
    </div>

    <div class="hero-visual hero-visual-image" aria-hidden="true">
      <img src="{{ page.relbaseurl }}/img/anyterial_network.png" alt="" />
    </div>
  </section>

  <section class="route-grid section-shell" aria-label="Primary resources">
    <article class="route-card database" id="databases">
      <div class="section-title-row">
        <span class="icon-badge" aria-hidden="true"><img src="{{ page.relbaseurl }}/icons/Hicon_Pack_1/database.svg" alt="" /></span>
        <h2>Databases</h2>
      </div>
      <p>Curated and computed materials databases for exploration, screening, and analysis.</p>
      <a class="inline-link" href="#databases">Browse databases <span aria-hidden="true">→</span></a>
      <div class="resource-list" aria-label="Database links">
        <a href="https://defects.anyterial.se"><strong>ADAQ</strong><span>Defect Database and Analysis</span></a>
        <a href="https://altermagnets.anyterial.se"><strong>AMDB</strong><span>Altermagnets Database</span></a>
        <a href="https://hadb.funmat-ii.se"><strong>HADB</strong><span>Hard-coating Alloys Database</span></a>
        <a href="https://openmaterialsdb.se"><strong>Open Materials Database</strong><span>Materials data</span></a>
      </div>
      <!--a class="footer-link" href="#databases">View all databases</a-->
    </article>

    <article class="route-card tools" id="tools">
      <div class="section-title-row">
        <span class="icon-badge" aria-hidden="true"><img src="{{ page.relbaseurl }}/icons/Hicon_Pack_1/tool.svg" alt="" /></span>
        <h2>Tools</h2>
      </div>
      <p>Software and services for high-throughput workflows, analysis, and infrastructure.</p>
      <a class="inline-link" href="#tools">Explore tools <span aria-hidden="true">→</span></a>
      <div class="resource-list" aria-label="Tool links">
        <a href="https://httk.org"><strong>High-Throughput Toolkit (httk)</strong><span>Workflow automation platform</span></a>
        <a href="https://status.anyterial.se"><strong>Anyterial service status</strong><span>Real-time status and uptime</span></a>
        <a href="https://github.com/anyterial"><strong>Other tools</strong><span>GitHub link to additional utilities and services</span></a>
      </div>
      <!--a class="footer-link" href="#tools">View all tools</a-->
    </article>

    <article class="route-card docs" id="docs">
      <div class="section-title-row">
        <span class="icon-badge" aria-hidden="true"><img src="{{ page.relbaseurl }}/icons/Hicon_Pack_1/book-open.svg" alt="" /></span>
        <h2>Docs</h2>
      </div>
      <p>Guides, references, and publications to help you use Anyterial resources.</p>
      <a class="inline-link" href="#docs">Read documentation <span aria-hidden="true">→</span></a>
      <div class="resource-list" aria-label="Documentation links">
        <a href="https://httk.org/"><strong>Getting started with <i>httk</i></strong><span>Quickstart guides</span></a>
        <a href="https://docs.httk.org"><strong>Full <i>httk</i> reference</strong><span>In-depth documentation</span></a>
        <a href="{{ page.relbaseurl }}/publications.html"><strong>Publications</strong><span>Papers and books</span></a>
      </div>
      <!--a class="footer-link" href="{{ page.relbaseurl }}/publications.html">View all docs</a-->
    </article>
  </section>

  <section class="metrics section-shell" aria-label="Anyterial highlights">
    <div class="metric"><span class="metric-icon" aria-hidden="true"><img src="{{ page.relbaseurl }}/icons/Hicon_Pack_1/box.svg" alt="" /></span><strong>200k+</strong><span>Materials</span></div>
    <div class="metric"><span class="metric-icon" aria-hidden="true"><img src="{{ page.relbaseurl }}/icons/Hicon_Pack_1/database.svg" alt="" /></span><strong>4</strong><span>Databases</span></div>
    <div class="metric"><span class="metric-icon" aria-hidden="true"><img src="{{ page.relbaseurl }}/icons/Hicon_Pack_1/bulb.svg" alt="" /></span><strong>1M+</strong><span>Calculations</span></div>
    <div class="metric"><span class="metric-icon" aria-hidden="true"><svg viewBox="0 0 640 640" xmlns="http://www.w3.org/2000/svg"><path d="M576 96C576 204.1 499.4 294.3 397.6 315.4C389.7 257.3 363.6 205 325.1 164.5C365.2 104 433.9 64 512 64L544 64C561.7 64 576 78.3 576 96zM64 160C64 142.3 78.3 128 96 128L128 128C251.7 128 352 228.3 352 352L352 544C352 561.7 337.7 576 320 576C302.3 576 288 561.7 288 544L288 384C164.3 384 64 283.7 64 160z" /></svg></span><strong>Open</strong><span>And growing</span></div>
  </section>

  <section class="split-panel section-shell" id="community" aria-label="Community and updates">
    <article id="about">
      <h2>Built on openness</h2>
      <p>The databases, tools, and resources are developed by a collaboration of academic institutions and is built on open data, open source, and open science principles.</p>
      <a class="inline-link" href="{{ page.relbaseurl }}/about.html">About Anyterial <span aria-hidden="true">→</span></a><br/>
      <a class="inline-link" href="https://optimade.org">About OPTIMADE <span aria-hidden="true">→</span></a>
    </article>

    <article>
      <h2>Stay up to date</h2>
      <p>Get the latest news, updates, and announcements from Anyterial.</p>
      <form class="subscribe" action="https://api.follow.it/subscription-form/S2p0TEcwTlcvMG9xS1N5N2hwYmo1Um9mTEdISHBBeGFibXc4aUVRbElhQjRKallLS3VCczJRSzAwOFN6YWdZZEtkNHE2VlhjYW1JaDZuS2hDV0Z2citjU0daa2VFVDdJNTVreklLMlR5WkVNQ0FlUWUxeW1ucmlFRFRVZkxtSlp8dmVXV0VxeDFBYUFpcE02Y09mZDZHZlBlNEcxYmQyeCsvaE50emZmSm42cz0=/8" method="post">
